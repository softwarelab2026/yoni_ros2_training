{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run pre-commits, tests and pylint",
            "type": "shell",
            "command": "pre-commit run --all-files && pylint ros2_ws/src/ball_tracker/ball_tracker/ && python3 -m pytest ros2_ws/tests/ -v",
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": []
        },
        {
            "label": "Clean, Build and Launch System",
            "type": "shell",
            "command": "rm -rf build install log && colcon build --symlink-install && source /opt/ros/humble/setup.bash && source install/setup.bash && ros2 launch ball_tracker ${input:launchFile}",
            "options": {
                "cwd": "${workspaceFolder}/ros2_ws",
                "shell": {
                    "executable": "/bin/bash",
                    "args": ["-c"]
                }
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "new",
                "clear": true
            },
            "problemMatcher": []
        }
    ],
    "inputs": [
        {
            "id": "launchFile",
            "type": "pickString",
            "description": "Which launch file would you like to run?",
            "options": [
                {
                    "label": "PID Tuning (Manual mode via rqt)",
                    "value": "pid_tuning.launch.py"
                },
                {
                    "label": "Ball Tracking (Automatic mode via Camera)",
                    "value": "ball_tracker.launch.py"
                }
            ],
            "default": "pid_tuning.launch.py"
        }
    ]
}
